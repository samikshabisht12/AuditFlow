# PostgreSQL Database
# You can either provide a full DATABASE_URL (Recommended for Supabase)
DATABASE_URL=PASTE_SUPABASE_CONNECTION_STRING_HERE

# OR provide individual credentials
DB_USER=postgres
DB_PASS=your_secure_password
DB_HOST=localhost:5432
DB_NAME=audit_db

# API Authentication Keys
ADMIN_API_KEY=your_admin_key_here
AUDITOR_API_KEY=your_auditor_key_here
VIEWER_API_KEY=your_viewer_key_here
